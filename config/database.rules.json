{
  "rules": {
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid",
        "profile": { ".validate": "newData.hasChildren(['displayName', 'email', 'createdAt'])" },
        "tokens": {
          "$token": {
            ".read": "$uid === auth.uid",
            ".write": "$uid === auth.uid"
          }
        }
      }
    },
    "projects": {
      "$pid": {
        ".read": "data.child('owner').val() === auth.uid",
        ".write": "data.child('owner').val() === auth.uid || !data.exists()",
        ".validate": "newData.hasChildren(['name', 'owner', 'runtime', 'createdAt', 'status'])",
        "owner": { ".validate": "newData.val() === auth.uid" },
        "env": {
          "$key": {
            ".read": "data.parent().parent().child('owner').val() === auth.uid",
            ".write": "data.parent().parent().child('owner').val() === auth.uid"
          }
        }
      }
    },
    "deployments": {
      "$did": {
        ".read": "root.child('projects').child(data.child('projectId').val()).child('owner').val() === auth.uid",
        ".write": "root.child('projects').child(data.child('projectId').val()).child('owner').val() === auth.uid"
      }
    },
    "instances": {
      "$iid": {
        ".read": "root.child('projects').child(data.child('projectId').val()).child('owner').val() === auth.uid",
        ".write": "root.child('projects').child(data.child('projectId').val()).child('owner').val() === auth.uid"
      }
    },
    "domains": {
      "$domain": {
        ".read": "root.child('projects').child(data.child('projectId').val()).child('owner').val() === auth.uid",
        ".write": "root.child('projects').child(data.child('projectId').val()).child('owner').val() === auth.uid"
      }
    },
    "logs": {
      "$lid": {
        ".read": "root.child('projects').child(data.child('projectId').val()).child('owner').val() === auth.uid",
        ".write": "root.child('projects').child(data.child('projectId').val()).child('owner').val() === auth.uid"
      }
    },
    "analytics": {
      "$aid": {
        ".read": "root.child('projects').child(data.child('projectId').val()).child('owner').val() === auth.uid",
        ".write": "root.child('projects').child(data.child('projectId').val()).child('owner').val() === auth.uid"
      }
    }
  }
}
