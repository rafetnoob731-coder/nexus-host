{
  "security": {
    "nexus": {
      "version": "2.0.0",
      "name": "NEXUS Security System",
      "description": "Enterprise-grade protection for NEXUS HOST platform"
    },
    "authentication": {
      "jwt": {
        "enabled": true,
        "provider": "firebase",
        "session_duration": "24h",
        "refresh_enabled": true
      },
      "oauth": {
        "google": {
          "enabled": true,
          "scopes": ["email", "profile"]
        }
      },
      "rate_limiting": {
        "login_attempts": 5,
        "lockout_duration": 300,
        "window_ms": 60000
      }
    },
    "deployment": {
      "sandboxing": {
        "enabled": true,
        "isolation": "container",
        "network_isolation": true,
        "filesystem_isolation": true
      },
      "tokens": {
        "length": 64,
        "prefix": "nxs_",
        "rotation_days": 90,
        "max_tokens_per_user": 10
      },
      "upload": {
        "max_size_bytes": 524288000,
        "allowed_extensions": [".zip"],
        "scan_for_malware": true,
        "validate_zip_structure": true,
        "block_dangerous_extensions": [
          ".exe", ".sh", ".bat", ".cmd", ".ps1",
          ".jar", ".dll", ".so", ".dylib", ".bin",
          ".msi", ".scr", ".pif", ".vbs"
        ]
      }
    },
    "api": {
      "abuse_protection": {
        "rate_limit": {
          "requests_per_minute": 60,
          "burst": 10
        },
        "ip_blacklisting": true,
        "request_validation": true
      },
      "cors": {
        "allowed_origins": ["https://nexus-host.app", "https://*.nexus-host.app"],
        "allowed_methods": ["GET", "POST", "PUT", "DELETE", "PATCH"],
        "allowed_headers": ["Content-Type", "Authorization", "X-Nexus-Token"]
      }
    },
    "encryption": {
      "environment_variables": {
        "method": "aes-256-gcm",
        "key_rotation": true
      },
      "session_data": {
        "encrypt": true,
        "algorithm": "aes-256-cbc"
      }
    },
    "firebase": {
      "rules_protection": {
        "validate_on_write": true,
        "owner_verification": true,
        "data_sanitization": true
      },
      "database": {
        "enforce_schema": true,
        "max_depth": 5,
        "max_records_per_query": 100
      }
    }
  }
}
